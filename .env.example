# Copy to .env.local and fill in values. Never commit .env.local.
#
# SECURITY: Do not prefix secrets with NEXT_PUBLIC_ — those are embedded in the
# browser bundle. Use ANTHROPIC_API_KEY (not NEXT_PUBLIC_ANTHROPIC_API_KEY).

# Auth.js / NextAuth (https://authjs.dev)
AUTH_SECRET=
# Dev: http://localhost:3000  Prod: your canonical URL
AUTH_URL=http://localhost:3000

# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: server-side AI album cover (https://console.anthropic.com)
ANTHROPIC_API_KEY=
