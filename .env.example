# Copy to .env.local and fill in values. Never commit .env.local.
#
# SECURITY: Do not prefix secrets with NEXT_PUBLIC_ — those are embedded in the
# browser bundle.

# Auth.js / NextAuth (https://authjs.dev)
AUTH_SECRET=
# Dev: http://localhost:3000  Prod: your canonical URL (origin only, no /api/auth path)
AUTH_URL=http://localhost:3000

# Optional: set to 1 on Vercel to GET /api/debug/auth-env (URL/header diagnostics). Remove after debugging.
# DEBUG_AUTH_ENV=1

# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
